# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deskdibs
DB_USER=deskdibs
DB_PASSWORD=changeme

# --- Auth provider: "local" for development, "entra" for Microsoft SSO ---
# Anything else stops the application at startup. "local" additionally refuses to
# start when the prod/production Spring profile is active.
AUTH_PROVIDER=local

# --- Local provider (development only) ---
# HMAC key for the tokens this application signs itself. At least 32 characters:
#   openssl rand -base64 48
# Leave blank and a random key is generated per process — logins keep working, but
# every issued token dies at restart and a second instance would reject the first's.
DESKDIBS_JWT_SECRET=
# Access token lifetime, ISO-8601 duration.
DESKDIBS_JWT_TTL=PT8H
# Issuer and audience the local tokens carry and are checked against.
DESKDIBS_JWT_ISSUER=deskdibs-local
DESKDIBS_JWT_AUDIENCE=deskdibs-api
# Password for the seeded dev accounts: employee@, manager@ and admin@deskdibs.local.
# BLANK MEANS NO SEEDING — nothing is invented and no password is ever written to the
# log. Set it to any value to get the three accounts on the next start.
DEV_SEED_PASSWORD=
# Set false to skip dev account seeding even when a password is configured.
DEV_SEED_USERS=true

# --- Microsoft Entra ID (leave blank until IT issues the app registration) ---
# Both are required when AUTH_PROVIDER=entra; the application refuses to start without
# them. Neither is secret: the tenant and client ids are public identifiers.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# Not used by the backend. DeskDibs is a bearer-token resource server: the browser runs
# the OIDC code flow and the backend only validates the resulting token, so there is no
# server-side secret exchange. Kept here for a future server-side flow only.
ENTRA_CLIENT_SECRET=
# Sovereign-cloud overrides (US Government, China). Blank derives both from the tenant id.
ENTRA_ISSUER=
ENTRA_JWK_SET_URI=

# --- Office rules ---
OFFICE_TIMEZONE=Asia/Kolkata
BOOKING_HORIZON_DAYS=14
TEAM_BLOCK_RELEASE_TIME=10:00
NO_SHOW_RELEASE_TIME=11:00
