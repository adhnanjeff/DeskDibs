# Credentials for the optional docker-compose stack (docker-compose.yml).
# Copy to .env.docker and set a value. .env.docker is gitignored.
#
#   cp .env.docker.example .env.docker
#
# This is a throwaway local container, not a production database. Never reuse
# a real credential here.

POSTGRES_DB=deskdibs
POSTGRES_USER=deskdibs
POSTGRES_PASSWORD=changeme

PGADMIN_DEFAULT_EMAIL=admin@deskdibs.local
PGADMIN_DEFAULT_PASSWORD=changeme
