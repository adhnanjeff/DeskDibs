# ─── Secrets — never commit ───────────────────────────────
.env
.env.local
.env.*.local
.env.docker
*.pem
*.key
*.p12
*.jks
.db_devpw_tmp

# ─── Java / Maven ─────────────────────────────────────────
target/
.mvn/timing.properties
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*
# Maven wrapper jar must stay tracked — negation must follow *.jar to win.
# Leading **/ is required: the wrapper lives in backend/.mvn, not the repo root.
!**/.mvn/wrapper/maven-wrapper.jar

# ─── Node / React ─────────────────────────────────────────
node_modules/
dist/
dist-ssr/
build/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Test & coverage output ───────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/
blob-report/
/playwright/.cache/

